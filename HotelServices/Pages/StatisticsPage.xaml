<Page x:Class="HotelServices.Pages.StatisticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Статистика"
      Background="#FFF8F9FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <Border Grid.Row="0" Padding="15" Background="#FFF8F9FA"
                BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="lblTitle" Grid.Column="0"
                           Text="📊 Статистика"
                           FontSize="24" FontWeight="Bold" Foreground="#2D5F8B"
                           VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.3" Color="#555555"/>
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentDateTime, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                           Foreground="#777777" FontSize="14" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Period + buttons -->
        <Border Grid.Row="1" Background="White" Margin="15,10,15,5"
                CornerRadius="8" BorderBrush="#DDDDDD" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="5" Opacity="0.1" Color="#555555"/>
            </Border.Effect>

            <StackPanel Orientation="Horizontal" Margin="10" VerticalAlignment="Center">
                <TextBlock x:Name="lblFrom" Text="Період з:" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontWeight="SemiBold" Foreground="#2D5F8B"/>
                <DatePicker x:Name="dpFrom" Width="140" Margin="0,0,15,0"/>

                <TextBlock x:Name="lblTo" Text="по:" VerticalAlignment="Center"
                           Margin="0,0,8,0" FontWeight="SemiBold" Foreground="#2D5F8B"/>
                <DatePicker x:Name="dpTo" Width="140" Margin="0,0,20,0"/>

                <Button x:Name="btnRefresh" Content="Оновити"
                        Click="Refresh_Click"
                        Style="{StaticResource ActionButtonStyle}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnBack" Content="На головну"
                        Click="BackToMain_Click"
                        Margin="10,0,0,0"
                        Style="{StaticResource ActionButtonStyle}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <!-- Stat cards -->
        <Border Grid.Row="2" Background="White" Margin="15,5,15,5"
                CornerRadius="8" BorderBrush="#DDDDDD" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="5" Opacity="0.1" Color="#555555"/>
            </Border.Effect>

            <ItemsControl x:Name="statsItemsControl" Margin="15">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="6" Padding="14"
                                Background="#FAFCFE"
                                BorderBrush="#DDE5EE" BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="12"
                                           Foreground="#777777"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding Value}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding Color}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Top resources table -->
        <Border Grid.Row="3" Background="White" Margin="15,5,15,15"
                CornerRadius="8" BorderBrush="#DDDDDD" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="1" BlurRadius="5" Opacity="0.1" Color="#555555"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="lblTopTitle" Grid.Row="0"
                           Text="Топ-5 найприбутковіших ресурсів"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="#2D5F8B"
                           Margin="15,12,15,8"/>

                <DataGrid x:Name="topGrid" Grid.Row="1" Margin="10,0,10,10">
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="colRank"     Header="#"     Binding="{Binding Rank}"     Width="Auto"/>
                        <DataGridTextColumn x:Name="colNameTop"  Header="Назва" Binding="{Binding Name}"     Width="*"/>
                        <DataGridTextColumn x:Name="colTypeTop"  Header="Тип"   Binding="{Binding TypeName}" Width="Auto"/>
                        <DataGridTextColumn x:Name="colRevenue"  Header="Дохід"
                                            Binding="{Binding Revenue, StringFormat='{}{0:N2} ₴'}"
                                            Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>