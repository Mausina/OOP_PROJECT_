<Window x:Class="HotelServices.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="dashboardWindow"
        Title="Головна панель" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Grid>
        <Frame x:Name="mainFrame" NavigationUIVisibility="Hidden"/>

        <!-- Language toggle button overlay (top-right corner) -->
        <Button x:Name="btnLang"
                Content="🌐 EN"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,6,12,0"
                Width="60" Height="26"
                FontSize="12"
                Cursor="Hand"
                Click="BtnLang_Click"
                Panel.ZIndex="100">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#304352"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#AAAAAA"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10" Padding="6,2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#0056b3"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>